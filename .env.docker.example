# Copie ce fichier en `.env.docker` à la racine du repo, puis remplace les valeurs
# factices par tes vrais secrets avant `docker compose up --build`.

NODE_ENV=development
PORT=5132
API_PREFIX=api/v1
APP_URL=http://localhost:5132
CORS_ORIGIN=http://localhost:8080

JWT_ACCESS_SECRET=change-me-please-use-at-least-32-chars!!
JWT_REFRESH_SECRET=change-me-too-please-32-chars-min!!

STREAM_API_KEY=stream-api-key-placeholder
STREAM_API_SECRET=stream-api-secret-placeholder

STRIPE_SECRET_KEY=sk_test_000000000000000000000000000000000000000000000000
STRIPE_PUBLISHABLE_KEY=pk_test_000000000000000000000000000000000000000000000000

RESEND_API_KEY=re_00000000000000000000000000000000

CLOUDINARY_CLOUD_NAME=demo
CLOUDINARY_API_KEY=000000000000000
