# ===============================================================================
# SLForce Backend — Environment variables template
#
# Usage:
#   1. Copy this file to .env at the project root
#   2. Fill every placeholder marked with [REPLACE]
#   3. NEVER commit .env — only .env.example is in git
#
# Naming convention:
#   • [REPLACE] = required, no default, will fail to boot if missing
#   • [optional] = has a sane default, only override if needed
# ===============================================================================

# ─── APPLICATION ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5132
API_PREFIX=api/v1

# ─── DATABASE (MongoDB) ───────────────────────────────────────────────────────
# [REPLACE] MongoDB Atlas connection string. Get it from your cluster's "Connect"
# button. Format: mongodb+srv://user:password@cluster.mongodb.net/database-name
MONGODB_URI=mongodb+srv://slforce_db:ppitcaHuZ7EuyPHP@cluster0.xufdy6s.mongodb.net/

# ─── JWT ──────────────────────────────────────────────────────────────────────
# [REPLACE] Two long random strings (≥ 64 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# DO NOT use the same secret for both — they isolate access and refresh tokens.
JWT_ACCESS_SECRET=replace-with-long-random-string-min-32-chars-please
JWT_ACCESS_EXPIRATION=7d
JWT_REFRESH_SECRET=replace-with-DIFFERENT-long-random-string-min-32-chars
JWT_REFRESH_EXPIRATION=30d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. "*" only acceptable in development.
CORS_ORIGIN=*

# ─── BCRYPT ───────────────────────────────────────────────────────────────────
# 12 is the modern sweet-spot (≈250ms hashing). Increase for higher security at the
# cost of slower auth. Range: 10–15.
BCRYPT_SALT_ROUNDS=12

# ─── STRIPE ───────────────────────────────────────────────────────────────────
# [REPLACE] All three are required for payments to work.
# Test keys: https://dashboard.stripe.com/test/apikeys
# Live keys: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxx
# Webhook signing secret. Get it after creating an endpoint in
# https://dashboard.stripe.com/test/webhooks → "Add endpoint"
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxx

# ─── STREAM CHAT ──────────────────────────────────────────────────────────────
# [REPLACE] Required for real-time messaging.
# Get them in https://dashboard.getstream.io → your app → "App Access Keys"
STREAM_API_KEY=stream_api_key_here
STREAM_API_SECRET=stream_api_secret_here

# ─── CLOUDINARY (image storage for avatars + chat attachments) ────────────────
# [REPLACE] Required for any image upload. Get them in your Cloudinary console:
# https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=cloudinary_cloud_name_here
CLOUDINARY_API_KEY=cloudinary_api_key_here
CLOUDINARY_API_SECRET=cloudinary_api_secret_here

# ─── PUBLIC URLS ──────────────────────────────────────────────────────────────
# [REPLACE in production] Used by Stripe Connect redirects + transactional emails.
# In dev: http://localhost:5132 — in prod: https://api.slforce.com (HTTPS REQUIRED)
BASE_URL=http://localhost:5132
# Deep link opened by the app when the user taps the reset email.
# Dev (Expo Go): exp://192.168.x.x:8081/--/(public)/reset-password
# Production:    slforce://reset-password
RESET_PASSWORD_URL=slforce://reset-password

# ─── RESEND (transactional emails) ────────────────────────────────────────────
# [REPLACE] Create your free API key at: https://resend.com/api-keys
# Free tier: 3 000 emails/month. No credit card required.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
MAIL_FROM=no-reply@slforce.app

# ─── REDIS (optional in dev, REQUIRED in multi-pod production) ────────────────
# Without Redis, rate limits and caches are per-process — when running multiple
# instances behind a load balancer, each instance has its own counters, so the
# real rate limit is multiplied by the number of pods.
# REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://:password@redis-host:6380   # TLS variant for managed Redis

# ─── SENTRY (optional — backend error tracking) ───────────────────────────────
# SENTRY_DSN=https://xxxxx@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── LOAD TESTING (NEVER set in production) ───────────────────────────────────
# Bypass token to disable rate limits during synthetic load tests.
# The app refuses to boot if NODE_ENV=production AND this is set.
# LOADTEST_BYPASS_TOKEN=slf-local-loadtest-token
