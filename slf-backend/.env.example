# ===============================================================================
# SLForce Backend — Template des variables d'environnement
#
# Usage :
#   1. Copie ce fichier : cp .env.example .env
#   2. Remplis chaque valeur marquée [REMPLACER]
#   3. Ne commite JAMAIS le fichier .env — seul ce template va sur Git
#
# Légende :
#   [REMPLACER] = obligatoire, le serveur refuse de démarrer si absent
#   [optionnel] = valeur par défaut correcte, ne change que si besoin
# ===============================================================================

# ─── APPLICATION ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5132
API_PREFIX=api/v1

# IP LAN de ta machine de développement.
# Utilisée pour construire les URLs des photos de profil uploadées,
# accessibles depuis le simulator ET le vrai téléphone sur le même Wi-Fi.
# Trouve ton IP avec : ipconfig getifaddr en0
# En production : remplace par ton domaine public (ex: api.slforce.com)
# [REMPLACER]
HOST=192.168.x.x

# URL complète du serveur — utilisée pour les redirections Stripe Connect.
# En dev : http://localhost:5132
# En prod : https://api.slforce.com  (HTTPS obligatoire)
APP_URL=http://localhost:5132

# ─── BASE DE DONNÉES (MongoDB Atlas) ──────────────────────────────────────────
# [REMPLACER] Chaîne de connexion Atlas.
# Récupère-la dans : ton cluster → "Connect" → "Connect your application"
# Format : mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/
MONGODB_URI=mongodb+srv://USER:MOT_DE_PASSE@cluster0.xxxxx.mongodb.net/

# ─── JWT ──────────────────────────────────────────────────────────────────────
# [REMPLACER] Deux chaînes aléatoires LONGUES et DIFFÉRENTES (min. 64 caractères).
# Génère-les avec cette commande :
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ⚠️ Ne jamais utiliser le même secret pour les deux — ils isolent access et refresh tokens.
JWT_ACCESS_SECRET=remplace_par_une_chaine_aleatoire_de_minimum_64_caracteres
# Access token court (15min) — combiné à la rotation refresh, ferme la fenêtre
# de compromission en cas de vol. Le frontend rafraîchit automatiquement via
# l'intercepteur 401 → /auth/refresh (single-flight).
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=remplace_par_une_AUTRE_chaine_aleatoire_de_minimum_64_caracteres
JWT_REFRESH_EXPIRATION=30d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# En développement : "*" pour tout autoriser
# En production : liste tes origines autorisées, ex: https://slforce.app
CORS_ORIGIN=*

# ─── BCRYPT ───────────────────────────────────────────────────────────────────
# 12 = bon équilibre sécurité/performance (~250ms par hash). [optionnel]
# Plage recommandée : 10–15.
BCRYPT_SALT_ROUNDS=12

# ─── STRIPE ───────────────────────────────────────────────────────────────────
# [REMPLACER] Les trois sont requis pour que les paiements fonctionnent.
# Clés de test : https://dashboard.stripe.com/test/apikeys
# Clés live    : https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_REMPLACE_PAR_TA_CLE_PUBLIABLE
STRIPE_SECRET_KEY=sk_test_REMPLACE_PAR_TA_CLE_SECRETE
# Secret de signature webhook — généré après création d'un endpoint dans :
# https://dashboard.stripe.com/test/webhooks → "Add endpoint" → copie le signing secret
STRIPE_WEBHOOK_SECRET=whsec_REMPLACE_PAR_TON_SECRET_WEBHOOK

# ─── STREAM CHAT (messagerie temps réel) ──────────────────────────────────────
# [REMPLACER] Requis pour la messagerie.
# Récupère-les dans : https://dashboard.getstream.io → ton app → "App Access Keys"
STREAM_API_KEY=REMPLACE_PAR_TA_CLE_API_STREAM
STREAM_API_SECRET=REMPLACE_PAR_TON_SECRET_API_STREAM

# ─── CLOUDINARY (stockage des photos de profil) ───────────────────────────────
# [REMPLACER] Requis pour les uploads de photos.
# Récupère-les dans : https://cloudinary.com/console → Dashboard
CLOUDINARY_CLOUD_NAME=REMPLACE_PAR_TON_CLOUD_NAME
CLOUDINARY_API_KEY=REMPLACE_PAR_TA_CLE_API_CLOUDINARY
CLOUDINARY_API_SECRET=REMPLACE_PAR_TON_SECRET_CLOUDINARY

# ─── URLS PUBLIQUES ───────────────────────────────────────────────────────────
# [REMPLACER en production] Utilisées par les redirections Stripe Connect
# et les templates d'e-mails transactionnels.
# En dev : http://localhost:5132 — En prod : HTTPS obligatoire
BASE_URL=http://localhost:5132

# Lien profond ouvert par l'app quand l'utilisateur clique sur le mail de reset.
# Dev (Expo Go) : exp://192.168.x.x:8081/--/(public)/reset-password
# Production    : slforce://reset-password
RESET_PASSWORD_URL=slforce://reset-password

# ─── RESEND (e-mails transactionnels) ─────────────────────────────────────────
# [REMPLACER] Crée ta clé gratuite sur : https://resend.com/api-keys
# Offre gratuite : 3 000 e-mails/mois, sans carte bancaire.
RESEND_API_KEY=re_REMPLACE_PAR_TA_CLE_RESEND
# Adresse expéditrice — doit être un domaine vérifié dans Resend
MAIL_FROM=no-reply@ton-domaine.com

# ─── REDIS (optionnel en dev, REQUIS en production multi-instances) ────────────
# Sans Redis, les rate-limits sont par processus. En production avec plusieurs
# instances derrière un load balancer, Redis est indispensable.
# REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://:password@redis-host:6380   (variante TLS pour Redis managé)

# ─── SENTRY (optionnel — suivi des erreurs backend) ───────────────────────────
# SENTRY_DSN=https://xxxxx@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── TESTS DE CHARGE (ne jamais activer en production) ────────────────────────
# Token pour désactiver les rate-limits lors des tests synthétiques.
# Le serveur refuse de démarrer si NODE_ENV=production ET cette variable est définie.
# LOADTEST_BYPASS_TOKEN=slf-local-loadtest-token
