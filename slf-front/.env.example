# ===============================================================================
# SLForce Frontend (Expo) — Environment variables template
#
# ⚠️ IMPORTANT: every variable prefixed with EXPO_PUBLIC_ is BUNDLED INTO THE
#    CLIENT APP. Never put secrets here — only public identifiers (API URL, public
#    Stripe keys, Stream Chat API key, Sentry DSN).
#
# Usage:
#   1. Copy this file to .env at the project root
#   2. Fill the placeholders
#   3. NEVER commit .env — only this template is in git
# ===============================================================================

# ─── BACKEND API ──────────────────────────────────────────────────────────────
# Where the app calls the backend.
#   • iOS simulator on the same Mac as the backend → http://localhost:5132/api/v1
#   • Real iPhone on the same Wi-Fi as the Mac     → http://<your-mac-ip>:5132/api/v1
#   • Production                                   → https://api.slforce.com/api/v1
EXPO_PUBLIC_API_BASE_URL=http://localhost:5132/api/v1

# ─── STREAM CHAT (real-time messaging) ────────────────────────────────────────
# This is the PUBLIC API key — same value the backend has under STREAM_API_KEY.
# Find it at https://dashboard.getstream.io → your app → "App Access Keys"
EXPO_PUBLIC_STREAM_CHAT_API_KEY=stream_api_key_here

# ─── STRIPE (payments) ────────────────────────────────────────────────────────
# This is the PUBLISHABLE key (pk_test_... or pk_live_...).
# Same value the backend has under STRIPE_PUBLISHABLE_KEY.
# https://dashboard.stripe.com/test/apikeys
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# ─── SENTRY (optional — frontend crash reporting) ─────────────────────────────
# Find your DSN at https://sentry.io → project settings → "Client Keys (DSN)"
# EXPO_PUBLIC_SENTRY_DSN=https://xxxxx@o0.ingest.sentry.io/0
# EXPO_PUBLIC_SENTRY_ENVIRONMENT=development
